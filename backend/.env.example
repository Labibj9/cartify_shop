PORT=5001
MONGO_URI=mongodb://127.0.0.1:27017/ecommerce
JWT_SECRET=replace_with_a_long_random_secret

# PayPal (Sandbox for development)
PAYPAL_CLIENT_ID=your_paypal_sandbox_client_id
